<ui:UXML xmlns:ui="UnityEngine.UIElements"
         xmlns:uie="UnityEditor.UIElements">

    <Style src="LobbyStyles.uss" />

    <!-- JOIN PANEL -->
    <ui:VisualElement name="join-panel" class="panel">
        <ui:Label text="TO THE TOP" class="panel-title" style="-unity-text-align: upper-center;" />

        <!-- Create Section -->
        <ui:VisualElement class="join-section">
            <ui:Label text="Create Lobby" class="join-section__title" />
            <ui:TextField name="lobby-name-input" />
            <ui:Button name="create-button" text="Create" class="btn btn--accent" />
        </ui:VisualElement>

        <!-- Lobby List Section -->
        <ui:VisualElement class="join-section">
            <ui:Label text="Join Lobby" class="join-section__title" />
            <ui:Label name="lobby-list-status" text="Loading..." />
            <ui:ScrollView name="lobby-list-scroll" />
            <ui:Button name="refresh-button" text="Refresh" class="btn" />
        </ui:VisualElement>
    </ui:VisualElement>

    <!-- LOBBY PANEL -->
    <ui:VisualElement name="lobby-panel" class="panel" style="display: none;">
        <ui:Label name="lobby-title" text="Lobby" class="panel-title" style="-unity-text-align: upper-center;" />
        <ui:Label name="lobby-status" class="panel-subtitle" style="-unity-text-align: upper-center;" />
        <ui:VisualElement name="player-list" />
        <ui:VisualElement style="flex-direction: row; align-self: center; margin-top: 12px;">
            <ui:Button name="ready-button" text="Ready Up" class="btn btn--accent btn--large" style="width: 200px;" />
            <ui:Button name="leave-button" text="Leave" class="btn btn--large" style="width: 120px; margin-left: 12px;" />
        </ui:VisualElement>
    </ui:VisualElement>

    <!-- COUNTDOWN PANEL -->
    <ui:VisualElement name="countdown-panel" class="panel" style="display: none;">
        <ui:Label name="countdown-text" text="3" />
    </ui:VisualElement>

    <!-- GAME PANEL -->
    <ui:VisualElement name="game-panel" class="panel" style="display: none;">
        <ui:Label name="timer-text" text="30s" />
        <ui:VisualElement name="bars-container" />
        <ui:Button name="tap-button" text="TAP!" class="btn btn--accent" />
    </ui:VisualElement>

    <!-- RESULTS PANEL -->
    <ui:VisualElement name="results-panel" class="panel" style="display: none;">
        <ui:Label name="results-text" text="" />
        <ui:VisualElement style="flex-direction: row; align-self: center; margin-top: 16px;">
            <ui:Button name="play-again-button" text="Play Again" class="btn btn--accent btn--large" style="width: 160px;" />
            <ui:Button name="quit-button" text="Quit" class="btn btn--large" style="width: 120px; margin-left: 12px;" />
        </ui:VisualElement>
    </ui:VisualElement>

</ui:UXML>
